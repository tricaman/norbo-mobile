# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copia in .env per il dev locale.
# In produzione (EAS Build), queste variabili sono settate automaticamente dai
# profili `preview` / `production` in `eas.json` e NON devono essere in .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── API URLs (DEV) ───────────────────────────────────────────────────────────
# Simulator: usa localhost. Device fisico sulla stessa LAN del Mac:
#   ifconfig | grep -E "inet "       (cerca un 192.168.* o 10.*)
# oppure su macOS:
#   ipconfig getifaddr en0
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_WS_URL=ws://localhost:8080/ws

# ── OAuth deep link scheme (deve coincidere con `scheme` in app.config.ts) ──
EXPO_PUBLIC_AUTH_CALLBACK_SCHEME=dit
